// [ADR-001 Accepted 2026-06-10: SaaS billing core boundaries]
goal "BillingCoreUsesAppendOnlyEvents" {
  rationale: "Amount-changing operations are auditable and cannot bypass the BillingEvent ledger"
  stakeholder: ["finance", "auditor", "security", "billing-admin"]
  measure: "invoice/payment/credit state changes have a source BillingEvent"
}

// [ADR-001 Accepted 2026-06-10: SaaS billing core boundaries]
goal "InvoiceProjectionUsesEventBackedAmounts" {
  rationale: "Invoice totals remain explainable and traceable to event-backed inputs"
  stakeholder: ["finance", "billing-admin"]
  measure: "invoice total projection references line item, tax, credit, and adjustment sources"
}

// [ADR-001 Accepted 2026-06-10: SaaS billing core boundaries]
goal "CreditApplicationUsesEventBackedBalance" {
  rationale: "Credit application cannot over-apply or silently change remaining balance"
  stakeholder: ["finance", "support"]
  measure: "credit application events reference credit id, amount, remaining balance, and invoice id"
}

// [ADR-001 Accepted 2026-06-10: SaaS billing core boundaries]
goal "PspAdapterCannotMutateInvoice" {
  rationale: "Payment provider integration cannot bypass invoice/payment domain rules"
  stakeholder: ["platform-engineer", "security", "billing-admin"]
  measure: "PSP adapter returns payment outcomes consumed by Payment module only"
}

// [ADR-001 Accepted 2026-06-10: SaaS billing core boundaries]
goal "TaxAdapterSuppliesTaxDataOnly" {
  rationale: "Billing core is tax-ready without claiming tax-compliant calculation ownership"
  stakeholder: ["finance", "auditor", "platform-engineer"]
  measure: "tax amount and jurisdiction data are supplied by adapter and stored as audit fields"
}
