//   - "module add 不能用，怎么更新模块？"
@source("PDR-003", section: "Intent Impact row 3")
@tobe
intent InitInstallsEmbeddedIntentCoder(r: IntentCoderInitResult) {
  require true
  ensure r.moduleDirExists' == true
  ensure r.skillsTreePresent' == true
  ensure r.intentValidateToolPresent' == true
  ensure r.doctorReportsModuleVersion' == true
}

// ---- Block 12 ----
// task:          T-CU-0012
// pdr:           PDR-003
// journey_stage: onboarding
// source:        PDR-003 § Intent Impact row 4
// query_anchors:
//   - "Popsicle DMG 里有什么？"
//   - "Install CLI.command 做了什么？"
