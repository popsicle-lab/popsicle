      "source": {
        "test_file": "tests/acceptance/domain_auth/test_horizontal_escalation.py",
        "test_name": "test_b_cannot_report_to_a_device",
        "test_framework": "pytest"
      },
      "reproduction": {
        "preconditions": [
          "Vera 启动 VERA_AUTH_ENABLED=true",
          "用户 A (project=1) 创建物模型并注册设备",
          "用户 B (project=2) 持有合法 Token"
        ],
        "steps": [
          "用户 B 用自己的 Token（project=2）调用 ReportProperties，目标为用户 A 的 model_id 和 device_id",
          "观察返回状态码"
        ],
        "expected": "返回 NOT_FOUND 或 PERMISSION_DENIED",
        "actual": "上报成功，数据被写入用户 A 的设备"
      },
      "evidence": {
        "log_snippet": "DID NOT RAISE <class 'grpc.RpcError'>",
        "code_location": "crates/vera-things/src/things/service.rs:1970-2020",
        "related_code": "report_properties 仅通过 extract_org_context 获取租户上下文，未校验目标 device 是否归属于当前请求的 org/project"
      },
      "tags": [
        "security,horizontal-escalation,cross-tenant,data-write"
      ]
    },
