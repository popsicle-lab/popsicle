        "test_name": "test_spoofed_header_create_in_other_project",
        "test_framework": "pytest"
      },
      "reproduction": {
        "preconditions": [
          "Vera 启动 VERA_AUTH_ENABLED=true",
          "用户 A (JWT claims org=1,project=1)"
        ],
        "steps": [
          "用户 A 的 Token + 篡改 x-project-id=2 调用 CreateThingModel",
          "观察返回状态码"
        ],
        "expected": "返回 PERMISSION_DENIED（JWT claims 中 project 与 header 不匹配）",
        "actual": "物模型在 project=2 下被成功创建"
      },
      "evidence": {
        "log_snippet": "DID NOT RAISE <class 'grpc.RpcError'>",
        "code_location": "crates/platform-api/src/header.rs:95-112",
        "related_code": "extract_org_context 中 x-org-id/x-project-id header 优先于 JWT claims，且不校验 header 值是否属于 JWT 声明的用户"
      },
      "tags": [
        "security,header-spoofing,horizontal-escalation,critical"
      ]
