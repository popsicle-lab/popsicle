// ============================================================
// Acceptance Intents（formal）— skill-runtime
// ============================================================
//
// 由 intent-spec-writer 从种子 acceptance.intent（prd-writer 4 block）收紧而来，
// 并消费 adr-writer 的 contracts-unlocked 工单（ADR-002 Accepted 2026-06-08）。
// 合并目标：products/skill-runtime/intents/acceptance.intent
// 来源 PDR：PDR-002 | ADR：ADR-002 | 生成日期：2026-06-08
//
// 角色：操作后置规约（require/ensure）。可直接 `intent check`，应 exit 0（全 trivial verified）。
// 保持型不变量在 invariants.intent；契约在 contracts.intent。
//
// 四条硬规则审查（逐条已过）：
//   1) 后态用 primed x'      —— 所有 ensure 均用 x'
//   2) 一文件一作用域         —— 本文件只放操作 intent，无 safety
//   3) 无 frame 需显式 x'==x —— 每条已补 frame ensure
//   4) 纯 require+ensure = trivial verified —— 本文件全 trivial verified（真不变量见 invariants.intent）
//
// ⚠️ 不含任何时间/性能/运行时约束（已剥离，见 intent-spec-report § 剥离清单）。
//
// Last-Updated: 2026-06-08
// Last-Decision-Ref: PDR-002 / ADR-002
// ============================================================

// ---- 领域类型（合并时与目标 acceptance.intent 去重；Skill 类型按 ADR-002 扩展）----

enum StageStatus { StageBlocked, StageReady, StageInProgress, StageCompleted, StageError }
enum PipelineRunStatus { RunPending, RunInProgress, RunCompleted, RunBlocked }
enum SkillStatus { Loaded, Active, Deprecated }

// ⚠️ 合并变更：原 Skill.version 按 ADR-002 拆为 pkgVersion + schemaVersion。
//    合并时替换目标文件的 Skill 类型，并同步 UpgradeDoesNotAffectCompletedRuns。
type Skill {
  name: String
  pkgVersion: String
  schemaVersion: String
  status: SkillStatus
}

type Stage {
  name: String
  status: StageStatus
  requiresApproval: Bool
  approvedAt: Int           // 0 = 未审批；> 0 = 审批时间戳
}

type PipelineRun {
  id: String
  status: PipelineRunStatus
  currentStageIndex: Int
  totalStages: Int
}

// ---- 操作 intent（每条对应一个 task）----

// task: T-0001 | pdr: PDR-002 | journey_stage: onboarding
// source: PDR-002 § "Intent Mapping" row 1
// query_anchors: ["popsicle-new 第一次怎么开始用？", "migration-bootstrap 跑到哪里会停下来等我？"]
@source("PDR-002", section: "Intent Mapping row 1")
@tobe
intent PipelineBootstrapsToFirstPause(r: PipelineRun, s: Stage) {
  require r.status == RunPending
  require s.status == StageBlocked
  ensure r.status' == RunInProgress
  ensure s.status' == StageInProgress
  ensure r.currentStageIndex' == r.currentStageIndex   // frame（规则3）
  ensure r.totalStages' == r.totalStages               // frame
}

// task: T-0002 | pdr: PDR-002 | journey_stage: daily-ops
// source: PDR-002 § "Intent Mapping" row 2
// query_anchors: ["怎么把一个 stage 标记为 completed？", "审批点 requires_approval 没过会怎么样？"]
@source("PDR-002", section: "Intent Mapping row 2")
@tobe
intent StageAdvanceWithApproval(s: Stage) {
  require s.status == StageInProgress
  require !s.requiresApproval || s.approvedAt > 0
  ensure s.status' == StageCompleted
  ensure s.requiresApproval' == s.requiresApproval     // frame
  ensure s.approvedAt' == s.approvedAt                 // frame
}

// task: T-0004 | pdr: PDR-002 | journey_stage: troubleshooting
// source: PDR-002 § "Intent Mapping" row 3
// query_anchors: ["stage 卡在 blocked 是什么意思？", "stage 失败后怎么重跑而不丢前面的产出？"]
@source("PDR-002", section: "Intent Mapping row 3")
@tobe
intent RecoveredPipelineCanAdvance(r: PipelineRun, s: Stage) {
  require r.status == RunBlocked
  require s.status == StageError
  ensure r.status' == RunInProgress
  ensure s.status' != StageError
  ensure r.currentStageIndex' == r.currentStageIndex   // frame：恢复不丢前面产出
  ensure r.totalStages' == r.totalStages               // frame
}

// task: T-0006 | pdr: PDR-002 | journey_stage: lifecycle
// source: PDR-002 § "Intent Mapping" row 4 + ADR-002（pkg/schema 双版本）
// query_anchors: ["skill 升级老的 pipeline 会被自动用新版吗？", "跑完的 run 升级后还可信吗？"]
@source("PDR-002", section: "Intent Mapping row 4")
@tobe
intent UpgradeDoesNotAffectCompletedRuns(r: PipelineRun, skOld: Skill, skNew: Skill) {
  require r.status == RunCompleted
  require skOld.name == skNew.name
  require skOld.pkgVersion != skNew.pkgVersion         // 包升级（ADR-002 双版本）
  ensure r.status' == RunCompleted                        // 冻结：仍 Completed
  ensure r.currentStageIndex' == r.currentStageIndex   // 未被回退
  ensure r.totalStages' == r.totalStages               // frame
}

// ============================================================
// 验证：`intent check` 本文件 → 5 个 intent 全 trivial verified、exit 0（预期；本环境无 intent 二进制，静态审查）。
// 真正的保持型不变量（HC-2 审批闸）见 invariants.intent。
// 已剥离/降级条目见 {slug}.intent-spec-report.md § 剥离清单。
// 合并：见 {slug}.intent-spec-report.md § 合并计划。
// ============================================================

