// Product: cli-ux
// Layer: L2 acceptance（验收契约 —— PROJ-6 / PDR-001）
// Status: formalized by intent-spec-writer
// Last-Updated: 2026-06-09
// Source PDR: PDR-001-cli-ux-command-tree-redesign.md
// Source ADR: ADR-007-cli-ux-io-shell-boundary.md
//
// 迁移口径：
// - 老 popsicle CLI facts 仅作为事实输入，不构成字节级兼容 baseline。
// - 新设计优先：cli-ux 是 thin IO shell，暴露 IDD 主路径、移除/defer 非 MVP 命令。
// - 性能、耗时和实现细节不进入 formal intent；它们归 task 成功标志和 delivery 检查。

type InitResult {
  workspaceReady: Bool
  hasNextStep: Bool
}

type IssueStartResult {
  runCreated: Bool
  specLocked: Bool
  hasRunId: Bool
}

type DocCreateResult {
  artifactFileExists: Bool
  documentRowExists: Bool
  hasDocId: Bool
}

type StageAdvanceResult {
  previousCompleted: Bool
  downstreamReady: Bool
  statusReflectsState: Bool
}

type ErrorResult {
  hasCategory: Bool
  hasObjectRef: Bool
  hasNextStep: Bool
}

type AdminResult {
  underAdminTree: Bool
  explicitWorkspace: Bool
}

@source("PDR-001", section: "Intent Mapping row 1")
@tobe
intent InitShowsNextStep(r: InitResult) {
  require r.workspaceReady
  ensure r.hasNextStep' == true
}

@source("PDR-001", section: "Intent Mapping row 2")
@tobe
intent IssueStartCreatesRun(r: IssueStartResult) {
  require true
  ensure r.runCreated' == true
  ensure r.specLocked' == true
  ensure r.hasRunId' == true
}

@source("PDR-001", section: "Intent Mapping row 3")
@tobe
intent DocCommandWritesArtifact(r: DocCreateResult) {
  require true
  ensure r.artifactFileExists' == true
  ensure r.documentRowExists' == true
  ensure r.hasDocId' == true
}

@source("PDR-001", section: "Intent Mapping row 4")
@tobe
intent StageAdvanceReflectsState(r: StageAdvanceResult) {
  require true
  ensure r.previousCompleted' == true
  ensure r.downstreamReady' == true
  ensure r.statusReflectsState' == true
}

@source("PDR-001", section: "Intent Mapping row 5")
@tobe
intent ErrorsAreActionable(r: ErrorResult) {
  require true
  ensure r.hasCategory' == true
  ensure r.hasObjectRef' == true
  ensure r.hasNextStep' == true
}

@source("PDR-001", section: "Intent Mapping row 6")
@tobe
intent AdminCommandsAreExplicit(r: AdminResult) {
  require true
  ensure r.underAdminTree' == true
  ensure r.explicitWorkspace' == true
}

// Verification:
// - products/cli-ux/intents/acceptance.intent: 6 intents verified.
// - products/cli-ux/intents/invariants.intent: RenderTopLevelHelp verified.
